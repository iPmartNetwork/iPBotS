# ===== Application =====
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=change-this-to-a-random-secret-key

# ===== Telegram Bot =====
BOT_TOKEN=your-telegram-bot-token
ADMIN_IDS=123456789,987654321
BOT_USERNAME=your_bot_username
SUPPORT_CHAT_ID=-100123456789

# ===== Database =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=v2ray_shop
DB_USER=postgres
DB_PASSWORD=your-secure-password

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Webhook =====
WEBHOOK_ENABLED=true
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/api/telegram/webhook
WEBHOOK_PORT=8443

# ===== Payment: ZarinPal =====
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_SANDBOX=false
ZARINPAL_CALLBACK_URL=https://your-domain.com/api/payment/zarinpal/callback

# ===== Payment: NowPayments =====
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-ipn-secret
NOWPAYMENTS_CALLBACK_URL=https://your-domain.com/api/payment/nowpayments/callback

# ===== Payment: Cryptomus =====
CRYPTOMUS_MERCHANT_ID=your-cryptomus-merchant-id
CRYPTOMUS_API_KEY=your-cryptomus-api-key
CRYPTOMUS_CALLBACK_URL=https://your-domain.com/api/payment/cryptomus/callback

# ===== Payment: Card to Card =====
CARD2CARD_ENABLED=true
CARD2CARD_NUMBER=6037-xxxx-xxxx-xxxx
CARD2CARD_HOLDER=نام صاحب کارت

# ===== Panel: 3x-ui =====
# Add panels via admin bot interface

# ===== Referral System =====
REFERRAL_ENABLED=true
REFERRAL_BONUS_PERCENT=10
REFERRAL_MIN_WITHDRAW=50000

# ===== Backup =====
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_CHAT_ID=-100123456789

# ===== Locale =====
DEFAULT_LANGUAGE=fa

# ===== AI Support (Optional) =====
OPENAI_API_KEY=your-openai-api-key-or-leave-empty

# ===== Payment: IDPay =====
IDPAY_API_KEY=your-idpay-api-key
IDPAY_SANDBOX=false
IDPAY_CALLBACK_URL=https://your-domain.com/api/payment/idpay/callback

# ===== Payment Notification Group =====
PAYMENT_GROUP_ID=0
PAYMENT_TOPIC_CARD2CARD_WALLET=0
PAYMENT_TOPIC_CARD2CARD_PURCHASE=0
PAYMENT_TOPIC_ONLINE=0
